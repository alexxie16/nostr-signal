# Nostr relay URLs (comma-separated)
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net

# Client-side relay URLs for posting (NEXT_PUBLIC_ required for browser)
NEXT_PUBLIC_NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net

# Use mock data when no real Nostr data is found (true/false)
NOSTR_USE_MOCK=false

